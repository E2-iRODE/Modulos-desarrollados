<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_search_order_form" model="ir.ui.view">
        <field name="name">wizard.search.order.form</field>
        <field name="model">wizard.search.order</field>
        <field name="arch" type="xml">
            <form string="Buscar Orden del Cliente">
                <sheet>
                    <div class="oe_title">
                        <h2>Buscar Orden —
                            <field name="partner_id" readonly="1"
                                style="display:inline; font-weight:700; color:#3b82f6;" />
                        </h2>
                    </div>

                    <field name="after_sale_id" invisible="1" />

                    <group col="4">
                        <group string="Productos" colspan="4">
    <field name="product_filter_ids"
        widget="many2many_tags"
        options="{'no_create': True, 'no_quick_create': True}"
        placeholder="Filtrar por producto..." />
</group>
                        <group string="Rango de fechas" colspan="2">
                            <field name="date_from" widget="date" />
                            <field name="date_to"   widget="date" />
                        </group>
                        <group string="Estados" colspan="2">
                            <field name="state_filter" />
                            <field name="invoice_status_filter" />
                            <field name="delivery_status_filter" />
                        </group>
                        <group string="Total de la orden" colspan="2">
                            <field name="amount_min" />
                            <field name="amount_max" />
                        </group>
                    </group>

                    <div style="display:flex; gap:8px; margin:4px 0 16px 0;">
                        <button name="action_apply_filters" string="Aplicar Filtros"
                            type="object" class="btn btn-primary" />
                        <button name="action_clear_filters" string="↺ Limpiar"
                            type="object" class="btn btn-secondary" />
                    </div>

                    <separator string="Órdenes encontradas" />

                    <field name="line_ids" nolabel="1">
                        <tree decoration-info="state == 'draft'"
                              decoration-success="state == 'sale'"
                              decoration-muted="state == 'done'"
                              decoration-danger="state == 'cancel'">
                            <field name="name"            string="Referencia" />
                            <field name="date_order"      string="Fecha" />
                            <field name="state" string="Estatus" widget="badge"
                                decoration-info="state == 'draft'"
                                decoration-primary="state == 'sent'"
                                decoration-success="state == 'sale'"
                                decoration-muted="state == 'done'"
                                decoration-danger="state == 'cancel'" />


                            <field name="invoice_status" string="Estatus Factura" widget="badge"
                                decoration-success="invoice_status == 'invoiced'"
                                decoration-warning="invoice_status == 'to invoice'"
                                decoration-muted="invoice_status == 'no'" 
                                decoration-danger="invoice_status not in ('invoiced','to invoice','no')"
                                />


                            <field name="delivery_status" string="Estatus Entrega" widget="badge"
                                decoration-info="delivery_status == 'started'"
                                decoration-warning="delivery_status == 'pending'"
                                decoration-success="delivery_status == 'full'"
                              decoration-danger="not delivery_status or delivery_status not in ('started','pending','full')" />


                            <field name="currency_id" column_invisible="True" />
                            <field name="amount_total" widget="monetary" string="Total"
                                options="{'currency_field': 'currency_id'}" />


                            <button name="action_select_line"
                                string="Seleccionar"
                                type="object"
                                icon="fa-check"
                                class="btn btn-sm btn-success" />
                        </tree>
                    </field>

                </sheet>
                <footer>
                    <button string="Cancelar" class="btn btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_search_order" model="ir.actions.act_window">
        <field name="name">Buscar Orden del Cliente</field>
        <field name="res_model">wizard.search.order</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="after_sale_app.model_after_sale" />
    </record>
</odoo>