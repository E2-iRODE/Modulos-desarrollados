<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="product_view_kanban_catalog_standalone" model="ir.ui.view">
    <field name="name">product.product.kanban.catalog.standalone</field>
    <field name="model">product.product</field>
    <field name="mode">primary</field>
    <field name="inherit_id" ref="product.product_view_kanban_catalog"/>
    <field name="arch" type="xml">
        
        <xpath expr="//kanban" position="attributes">
            <attribute name="js_class"></attribute>
            <attribute name="create">0</attribute>
            <attribute name="quick_create">0</attribute>
            <attribute name="default_group_by">categ_id</attribute>
        </xpath>

        <xpath expr="//div[hasclass('oe_kanban_details')]" position="inside">
            <div class="o_kanban_button mt-2">
                <button name="action_quick_add" 
                        type="object" 
                        class="btn btn-primary btn-sm">
                    Añadir a la Orden
                </button>
            </div>
        </xpath>

        <xpath expr="//div[@name='o_kanban_price']" position="inside">
            <field name="lst_price" widget="monetary"/>
        </xpath>
    </field>
</record>

</odoo>