<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TREE VIEW -->
    <record id="view_after_sale_tree" model="ir.ui.view">
        <field name="name">after.sale.tree</field>
        <field name="model">after.sale</field>
        <field name="arch" type="xml">
            <tree string="Seguimiento de Ventas" decoration-info="state == 'draft'"
                default_order="create_date desc">
                <field name="referencia" />

                <field name="partner_id" />
                <field name="date" string="Fecha de Seguimiento" />
                <field name="state"
                    widget="badge"
                    decoration-success="state == 'done'"
                    decoration-warning="state == 'in_progress'" />
            </tree>
        </field>
    </record>


  <record id="view_after_sale_kanban" model="ir.ui.view">
    <field name="name">after.sale.kanban</field>
    <field name="model">after.sale</field>
    <field name="arch" type="xml">
        <kanban default_group_by="state" quick_create="false" records_draggable="true">
            <field name="state" />
            <field name="referencia" />
            <field name="partner_id" />
            <field name="date" />

            <!-- Colores automáticos por estado -->
            

            <templates>
                <style>
                    /* Hover effect para las tarjetas */
.o_kanban_after_sale_card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.14) !important;
    transform: translateY(-2px);
}

/* Columnas del kanban más limpias */
.o_kanban_group {
    background: #f8fafc !important;
    border-radius: 14px !important;
    border: 1px solid #e2e8f0 !important;
}

/* Título de columna */
.o_kanban_group .o_column_title {
    font-weight: 700 !important;
    font-size: 13px !important;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #64748b !important;
    padding: 12px 16px !important;
}
                </style>
                <t t-name="kanban-box">

                    <!-- Color dinámico según estado -->
                    <t t-set="state_color"
                        t-value="record.state.raw_value == 'draft' ? '#f59e0b' :
                                 record.state.raw_value == 'in_progress' ? '#3b82f6' :
                                 record.state.raw_value == 'done' ? '#10b981' : '#6b7280'" />

                    <t t-set="state_bg"
                        t-value="record.state.raw_value == 'draft' ? '#fffbeb' :
                                 record.state.raw_value == 'in_progress' ? '#eff6ff' :
                                 record.state.raw_value == 'done' ? '#f0fdf4' : '#f9fafb'" />

                    <t t-set="state_label"
                        t-value="record.state.raw_value == 'draft' ? '📋 Borrador' :
                                 record.state.raw_value == 'in_progress' ? '🔄 En seguimiento' :
                                 record.state.raw_value == 'done' ? '✅ Cerrado' : record.state.value" />

                    <div t-attf-class="oe_kanban_global_click o_kanban_after_sale_card"
                         t-attf-style="
                             border-left: 5px solid #{state_color};
                             background: #{state_bg};
                             border-radius: 12px;
                             box-shadow: 0 2px 8px rgba(0,0,0,0.08);
                             transition: box-shadow 0.2s ease, transform 0.15s ease;
                             overflow: hidden;
                             margin-bottom: 8px;
                         ">

                        <!-- Barra superior de color -->
                        <div t-attf-style="
                            height: 4px;
                            background: linear-gradient(90deg, #{state_color}, #{state_color}88);
                            margin-bottom: 0;
                        "/>

                        <div style="padding: 14px 16px 12px;">

                            <!-- Título / Referencia -->
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                                <strong style="
                                    font-size: 14px;
                                    font-weight: 700;
                                    color: #1e293b;
                                    line-height: 1.3;
                                    flex: 1;
                                ">
                                    <field name="referencia" />
                                </strong>
                            </div>

                            <!-- Cliente -->
                            <div style="
                                display: flex;
                                align-items: center;
                                gap: 6px;
                                margin-bottom: 10px;
                            ">
                                <span style="font-size: 13px;">👤</span>
                                <span style="
                                    font-size: 13px;
                                    color: #475569;
                                    font-weight: 500;
                                ">
                                    <field name="partner_id" />
                                </span>
                            </div>

                            <!-- Footer: fecha + estado -->
                            <div style="
                                display: flex;
                                justify-content: space-between;
                                align-items: center;
                                padding-top: 8px;
                                border-top: 1px solid rgba(0,0,0,0.07);
                            ">
                                <!-- Fecha -->
                                <div style="
                                    display: flex;
                                    align-items: center;
                                    gap: 5px;
                                    font-size: 12px;
                                    color: #94a3b8;
                                ">
                                    <span>📅</span>
                                    <field name="date" widget="date" />
                                </div>

                                <!-- Badge de estado -->
                                <span t-attf-style="
                                    background: #{state_color}22;
                                    color: #{state_color};
                                    border: 1px solid #{state_color}55;
                                    padding: 2px 10px;
                                    border-radius: 20px;
                                    font-size: 11px;
                                    font-weight: 600;
                                    white-space: nowrap;
                                ">
                                    <t t-esc="state_label" />
                                </span>
                            </div>

                        </div>
                    </div>

                </t>
            </templates>
        </kanban>
    </field>
</record>

    <!-- FORM ORIGINAL -->
    <record id="view_after_sale_form" model="ir.ui.view">
        <field name="name">after.sale.form</field>
        <field name="model">after.sale</field>

        <field name="arch" type="xml">
            <form string="Seguimiento de Venta">

                <header>
                    <button name="action_confirm"
                        string="Confirmar"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'draft'" />

                    <button name="action_cerrar"
                        string="Cerrar"
                        type="object"
                        class="oe_highlight"
                    />
                    
                    <button name="action_wizard_search_order_nueva"
                        string="Nueva orden Existente"
                        type="object"
                        class="oe_highlight"
                        icon="fa-plus" />

                    <field name="state"
                        widget="statusbar"
                        statusbar_visible="draft,in_progress,done" />

                    <button name="action_new_sale_order_inline"
                        string="Relacionar Nueva orden"
                        type="object"
                        class="oe_highlight"
                        icon="fa-plus" />

                    <button name="action_open_catalog" string="Productos Sugeridos" type="object"
                        class="oe_highlight" />

                    <button name="action_restablecer_borrador"
    string="Restablecer a Borrador"
    type="object"
    class="oe_highlight"
    invisible="state != 'done'"
    />

                </header>


                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="referencia" placeholder="Referencia..." readonly="1" />
                        </h1>
                    </div>


                    <group>
                        <group>

                            <field name="partner_id" required="1" readonly="state != 'draft'" />
                     
                            






<label for="order_id" string="Orden de Venta" />
<div class="o_row" style="display: flex; align-items: center; gap: 6px;">
    <field name="order_id"
        nolabel="1"
        readonly="state != 'draft'"
        options="{'no_create': True, 'no_quick_create': True}"
        widget="many2one"
        style="flex: 1;" />
    <button name="action_open_search_order_wizard"
        type="object"
        icon="fa-search"
        class="btn btn-sm btn-info"
        style="height: 30px; width: 30px; padding: 0; flex-shrink: 0;"
        title="Abre el buscador avanzado de órdenes del cliente seleccionado"
         invisible="state != 'draft'"  />
</div>






                            <field name="order_state" widget="badge"
                                decoration-info="order_state == 'draft'"
                                decoration-success="order_state == 'sale'" />


                            <field name="invoice_status" widget="badge"
                                decoration-warning="invoice_status == 'to invoice'"
                                decoration-success="invoice_status == 'invoiced'" />


                            <field name="delivery_status" widget="badge"
                                decoration-info="delivery_status == 'pending'"
                                decoration-warning="delivery_status == 'started'"
                                decoration-success="delivery_status == 'full'" />

                            <field name="currency_id" invisible="1" />
                            <field name="date_order" readonly="1" />

                            <field name="order_total" widget="monetary"
                                options="{'currency_field': 'currency_id'}" />
                        </group>







                        <group>
                            <field name="user_id" widget="many2many_tags" required="1" />
                            <field name="date" string="Fecha de Seguimiento" required="1" />
                        </group>

                    </group>


                    <notebook>
                        <!-- Artículos del Pedido por Lote/Serie -->
                        <page string="Artículos del Pedido">
                            <button name="action_refresh_lotes"
                                string="↻ Actualizar Lotes"
                                type="object"
                                class="btn btn-sm btn-secondary mb-2"
                                title="Recalcula las filas de lotes/series desde las entregas" />

                            <field name="linea_lote_ids" readonly="1">
                                <tree decoration-muted="lote_nombre == '' or lote_nombre == 'Sin lote'"
                                      decoration-success="qty_entregada &gt;= qty_ordenada and qty_ordenada &gt; 0"
                                      decoration-warning="qty_entregada &gt; 0 and qty_entregada &lt; qty_ordenada">
                                    <field name="product_id" />
                                    <field name="lote_nombre" string="Lote / Serie" />
                                    <field name="qty_ordenada" string="Cant. Ordenada" />
                                    <field name="qty_entregada" string="Cant. Entregada" />
                                    <field name="currency_id" column_invisible="True" />
                                    <field name="price_unit" widget="monetary"
                                        options="{'currency_field': 'currency_id'}"
                                        string="Precio Unit." />
                                    <field name="stock_actual"
                                        string="Stock Real"
                                        decoration-bf="True"
                                        decoration-danger="stock_actual &lt;= 0"
                                        decoration-warning="stock_actual &gt; 0 and stock_actual &lt; qty_ordenada"
                                        decoration-success="stock_actual &gt;= qty_ordenada" />
                                </tree>
                            </field>
                        </page>

<page string="Órdenes Relacionadas">
    <field name="order_nueva" widget="many2many">
        <tree decoration-info="state == 'draft'">
 
            <field name="name" />
            <field name="date_order" />
 
            <field name="state"
                widget="badge"
                decoration-info="state == 'draft'"
                decoration-primary="state == 'sent'"
                decoration-success="state == 'sale'"
                decoration-muted="state == 'done' or not state"
                decoration-danger="state == 'cancel'" />
 
            <field name="delivery_status"
                widget="badge"
                decoration-info="delivery_status == 'started'"
                decoration-warning="delivery_status == 'pending' or delivery_status == 'partial'"
                decoration-success="delivery_status == 'full'"
             decoration-danger="delivery_status and delivery_status not in ('started', 'pending', 'partial', 'full', 'no')" />
 
            <field name="invoice_status"
                widget="badge"
                decoration-success="invoice_status == 'invoiced'"
                decoration-warning="invoice_status == 'to invoice'"
                decoration-muted="invoice_status == 'no' or not invoice_status"
                decoration-info="invoice_status == 'upselling'" />
 
            <field name="currency_id" column_invisible="True" />
            <field name="amount_total"
                string="Total de la Venta"
                widget="monetary"
                options="{'currency_field': 'currency_id'}" />
 
        </tree>
    </field>
</page>
                        <page string="Notas">
                            <field name="notes" widget="text" placeholder="Escribe una nota..." />
                        </page>

                    </notebook>

                </sheet>
  <div class="oe_chatter">
    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
    <field name="activity_ids" widget="mail_activity"/>
    <field name="message_ids" widget="mail_thread" options="{'post_refresh': 'recipients'}"/>
</div>
            </form>
        </field>
    </record>


    <!-- ACTION -->


    <record id="action_after_sale" model="ir.actions.act_window">
        <field name="name">Seguimiento de Ventas</field>
        <field name="res_model">after.sale</field>
        <field name="view_mode">kanban,tree,form</field>
        
        
    </record>


    <!-- ACTION CLIENTES -->
    <record id="action_after_sale_customers" model="ir.actions.act_window">
        <field name="name">Clientes de Post-Venta</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>


    <!-- MENUS -->
    <menuitem id="menu_after_sale_root"
        name="Seguimiento de Ventas"
        sequence="10" 
        web_icon="after_sale_app,static/description/icon.png"
        />

    <menuitem id="menu_after_sale_main"
        name="Seguimiento"
        parent="menu_after_sale_root"
        action="action_after_sale"
        sequence="10" />

    <menuitem id="menu_after_sale_customers"
        name="Clientes"
        parent="menu_after_sale_root"
        action="action_after_sale_customers"
        sequence="20" />

</odoo>