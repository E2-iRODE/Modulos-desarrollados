<odoo>
    <record id="module_category_after_sale" model="ir.module.category">
    <field name="name">Seguimiento de Ventas</field>
    <field name="sequence">20</field>
</record>

<record id="group_after_sale_user" model="res.groups">
    <field name="name">Usuario</field>
    <field name="category_id" ref="module_category_after_sale"/>
    <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
</record>

<record id="group_after_sale_manager" model="res.groups">
    <field name="name">Usuario Avanzado</field>
    <field name="category_id" ref="module_category_after_sale"/>
    <field name="implied_ids" eval="[(4, ref('group_after_sale_user'))]"/>
</record>
</odoo>