<?xml version="1.0" encoding="utf-8"?>
<odoo>

  

    <record id="aged_receivable_report_fel_gt_dte_number" model="account.report.column">
        <field name="report_id" ref="account_reports.aged_receivable_report"/>
        <field name="name">No. DTE</field>
        <field name="expression_label">fel_gt_dte_number</field>
        <field name="figure_type">string</field>
        <field name="sequence" eval="15"/>
    </record>

    <record id="aged_receivable_report_fel_gt_serie" model="account.report.column">
        <field name="report_id" ref="account_reports.aged_receivable_report"/>
        <field name="name">Serie DTE</field>
        <field name="expression_label">fel_gt_serie</field>
        <field name="figure_type">string</field>
        <field name="sequence" eval="16"/>
    </record>

    <record id="aged_receivable_line_fel_gt_dte_number" model="account.report.expression">
        <field name="report_line_id" ref="account_reports.aged_receivable_line"/>
        <field name="label">fel_gt_dte_number</field>
        <field name="engine">custom</field>
        <field name="formula">_report_custom_engine_aged_receivable</field>
        <field name="subformula">fel_gt_dte_number</field>
        <field name="auditable" eval="False"/>
    </record>

    <record id="aged_receivable_line_fel_gt_serie" model="account.report.expression">
        <field name="report_line_id" ref="account_reports.aged_receivable_line"/>
        <field name="label">fel_gt_serie</field>
        <field name="engine">custom</field>
        <field name="formula">_report_custom_engine_aged_receivable</field>
        <field name="subformula">fel_gt_serie</field>
        <field name="auditable" eval="False"/>
    </record>


    <record id="aged_payable_report_provider_invoice_number" model="account.report.column">
        <field name="report_id" ref="account_reports.aged_payable_report"/>
        <field name="name">No. Factura</field>
        <field name="expression_label">provider_invoice_number</field>
        <field name="figure_type">string</field>
        <field name="sequence" eval="15"/>
    </record>

    <record id="aged_payable_report_provider_invoice_serial" model="account.report.column">
        <field name="report_id" ref="account_reports.aged_payable_report"/>
        <field name="name">Serie Factura</field>
        <field name="expression_label">provider_invoice_serial</field>
        <field name="figure_type">string</field>
        <field name="sequence" eval="16"/>
    </record>

    <record id="aged_payable_line_provider_invoice_number" model="account.report.expression">
        <field name="report_line_id" ref="account_reports.aged_payable_line"/>
        <field name="label">provider_invoice_number</field>
        <field name="engine">custom</field>
        <field name="formula">_report_custom_engine_aged_payable</field>
        <field name="subformula">provider_invoice_number</field>
        <field name="auditable" eval="False"/>
    </record>

    <record id="aged_payable_line_provider_invoice_serial" model="account.report.expression">
        <field name="report_line_id" ref="account_reports.aged_payable_line"/>
        <field name="label">provider_invoice_serial</field>
        <field name="engine">custom</field>
        <field name="formula">_report_custom_engine_aged_payable</field>
        <field name="subformula">provider_invoice_serial</field>
        <field name="auditable" eval="False"/>
    </record>

</odoo>
