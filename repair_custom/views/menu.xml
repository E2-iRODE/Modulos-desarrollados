<odoo>
    <record id="product_marca_view_form" model="ir.ui.view">
        <field name="name">product.marca.view.form</field>
        <field name="model">product.marca</field>
        <field name="arch" type="xml">
            <form string="Marca">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_marca_view_tree" model="ir.ui.view">
        <field name="name">product.marca.view.tree</field>
        <field name="model">product.marca</field>
        <field name="arch" type="xml">
            <tree string="Marcas">
                <field name="name"/>
            </tree>
        </field>
    </record> <record id="action_marca_product" model="ir.actions.act_window">
        <field name="name">Marcas</field>
        <field name="res_model">product.marca</field>
        <field name="view_mode">tree,form</field>
    </record>
