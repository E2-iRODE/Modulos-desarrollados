

<odoo>
<record id="view_repair_order_form_inherit_filter" model="ir.ui.view">
        <field name="name">repair.order.form.filter.product</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//form" position="inside">
                <field name="compatible_products" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='move_ids']//field[@name='product_id']" position="attributes">
                <attribute name="domain">[('id', 'in', parent.compatible_products)]</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="seleccion_reparacion" />
            </xpath>

            <xpath expr="//field[@name='product_id']" position="attributes">
                <attribute name="invisible">seleccion_reparacion</attribute>
            </xpath>

            <xpath expr="//field[@name='product_id']" position="after">
                <field name="vehiculo_id" invisible="not seleccion_reparacion"/>
            </xpath>

        </field>
    </record>
</odoo>
