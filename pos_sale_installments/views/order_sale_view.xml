<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_order_sale_form_inherit_installment" model="ir.ui.view">
            <field name="name">sale.order.form.inherit.installment.term</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_term_id']" position="after">

                    <field name="installment_term_id"
                           string="Plan de cuotas"
                           options="{'no_create': True, 'no_open': True}"
                    />
                    
                    <field name="installment_count"
                           string="Cuotas"
                           readonly="1"
                           invisible="not installment_term_id"
                    />
                    <field name="installment_surcharge"
                           string="Recargo (%)"
                           readonly="1"
                           invisible="not installment_term_id"
                    />
                     <field name="installment_name"
                           string="Metodo de pago"
                           readonly="1"
                           invisible="not installment_term_id"
                    />


                </xpath>
            </field>
        </record>
    </data>
</odoo>
